{
  "entities": {
    "Book": {
      "title": "Book",
      "description": "A book published by the scholar.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the book" },
        "description": { "type": "string", "description": "Description of the book" },
        "category": { "type": "string", "description": "Category of the book" },
        "imageUrl": { "type": "string", "description": "URL of the book cover image" },
        "pdfUrl": { "type": "string", "description": "URL of the book PDF file" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "category", "imageUrl", "pdfUrl", "createdAt"]
    },
    "AudioLecture": {
      "title": "Audio Lecture",
      "description": "An audio lecture by the scholar.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the lecture" },
        "description": { "type": "string", "description": "Description of the lecture" },
        "category": { "type": "string", "description": "Category of the lecture" },
        "soundcloudUrl": { "type": "string", "description": "SoundCloud embed URL" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "category", "soundcloudUrl", "createdAt"]
    },
    "VideoLecture": {
      "title": "Video Lecture",
      "description": "A video lecture by the scholar.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the video" },
        "description": { "type": "string", "description": "Description of the video" },
        "category": { "type": "string", "description": "Category of the video" },
        "youtubeUrl": { "type": "string", "description": "YouTube embed URL" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "category", "youtubeUrl", "createdAt"]
    },
    "Reflection": {
      "title": "Reflection",
      "description": "A short reflection or thought by the scholar.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the reflection" },
        "text": { "type": "string", "description": "Text content of the reflection" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "text", "createdAt"]
    },
    "Pamphlet": {
      "title": "Pamphlet",
      "description": "A short pamphlet by the scholar.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the pamphlet" },
        "description": { "type": "string", "description": "Description of the pamphlet" },
        "imageUrl": { "type": "string", "description": "URL of the pamphlet preview image" },
        "pdfUrl": { "type": "string", "description": "URL of the pamphlet PDF file" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "imageUrl", "pdfUrl", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A message sent from the contact form.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Sender name" },
        "email": { "type": "string", "format": "email", "description": "Sender email" },
        "subject": { "type": "string", "description": "Message subject" },
        "message": { "type": "string", "description": "Message content" },
        "status": { "type": "string", "enum": ["new", "read", "archived"], "description": "Message status" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "subject", "message", "status", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile.",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["admin", "user"] },
        "email": { "type": "string", "format": "email" }
      },
      "required": ["role", "email"]
    }
  },
  "firestore": {
    "/books/{bookId}": {
      "schema": { "$ref": "#/entities/Book" },
      "description": "Stores books."
    },
    "/audio/{audioId}": {
      "schema": { "$ref": "#/entities/AudioLecture" },
      "description": "Stores audio lectures."
    },
    "/videos/{videoId}": {
      "schema": { "$ref": "#/entities/VideoLecture" },
      "description": "Stores video lectures."
    },
    "/reflections/{reflectionId}": {
      "schema": { "$ref": "#/entities/Reflection" },
      "description": "Stores reflections."
    },
    "/pamphlets/{pamphletId}": {
      "schema": { "$ref": "#/entities/Pamphlet" },
      "description": "Stores pamphlets."
    },
    "/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Stores messages from the contact form."
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles and roles."
    }
  }
}
